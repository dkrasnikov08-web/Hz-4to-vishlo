# Шаблон переменных окружения. Скопируйте в .env и заполните реальными значениями.
# Файл .env НЕ должен попадать в git (см. .gitignore) и должен иметь права 600.
#
#   cp .env.example .env
#   chmod 600 .env
#   nano .env   # вставить реальные ключи

BYBIT_API_KEY=your_key_here
BYBIT_API_SECRET=your_secret_here
BYBIT_TESTNET=true
